# Copy this file to .env and fill in ONE of the two keys below.

# Option A — Portkey gateway (NeoCognition's company plan, no per-account rate limits).
# Get yours at https://app.portkey.ai/api-keys.
PORTKEY_API_KEY=

# Option B — Direct Anthropic API (only if you don't have Portkey access).
# Get one at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=

# Optional model override.
# - For Portkey: defaults to "@anthropic/claude-sonnet-4-6"
# - For direct Anthropic: defaults to "claude-sonnet-4-6"
# MODEL=

# Optional — defaults to 8000
# PORT=8000
